#loadingOverlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(245, 245, 245, 0.95);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(6px);
}

.loaderBox {
  text-align: center;
}

.spinner {
  border: 6px solid #ccc;
  border-top: 6px solid #007bff;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  animation: spin 1s linear infinite;
  margin: 0 auto 16px;
}

.loadingText {
  font-size: 18px;
  color: #333;
  font-weight: 500;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

#extraContainer {
  padding: 40px;
    background: #f7f7f7;
    border: 1px solid #d1d1d1;
   margin-top:20px;
}

.aboutSection {
  text-align: center;
  margin-bottom: 40px;
}

.aboutSection h2 {
  font-size: 28px;
  margin-bottom: 16px;
  color: #333;
}

.aboutText {
  max-width: 800px;
  margin: 0 auto;
  font-size: 16px;
  line-height: 1.6;
  color: #444;
  text-align: left;
}

.infoFlex {
  display: flex;
  gap: 40px;
  justify-content: space-between;
  flex-wrap: wrap;
}

.infoPanel {
  width: 30%;
  background: #fff;
  border-radius: 10px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.infoPanel h3 {
  margin-bottom: 16px;
  font-size: 22px;
  border-bottom: 1px solid #ddd;
  padding-bottom: 8px;
  color: #555;
}

.infoItem {
  margin-bottom: 12px;
  font-size: 15px;
  color: #333;
}

.infoItem span {
  font-weight: bold;
  margin-right: 6px;
  color: #777;
}

.placeholderPanel {
  flex: 1;
  background: #fff;
  border-radius: 10px;
  min-height: 200px;
  padding: 20px;
}

.aboutSectionAndInfo {
  display: flex;
  flex-direction: column;
  gap: 40px;
}
.rankTimeline {
  position: relative;
  margin-top: 20px;
}

.rank {
  position: relative;
  padding-left: 30px;
  margin-bottom: 30px;
}

.rank::before {
  content: "";
  position: absolute;
  left: 11px;
  top: 0;
  width: 10px;
  height: 10px;
  background: gray;
  border-radius: 50%;
  z-index: 2;
}

.rank::after {
  content: "";
  position: absolute;
  left: 15px;
  top: 10px;
  bottom: -22px;
  width: 2px;
  background: #ccc;
  z-index: 1;
}

.rank:last-child::after {
  display: none;
}

.rank.earned::before {
  background: #4caf50;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7);
  }
  50% {
    box-shadow: 0 0 0 10px rgba(76, 175, 80, 0);
  }
}

.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 10px;
}

.badge {
  background: #f7f9fc;
  padding: 10px 15px;
  border-radius: 8px;
  width: 295px;
  box-shadow: 0 0 4px rgba(0,0,0,0.05);
  font-size: 14px;
}

.badge strong {
  display: inline-block;
  font-weight: bold;
  margin-bottom: 7px;
}

.badge small {
  color: #555;
}

.badges-unearned .badge {
  opacity: 0.5;
}

